{
  "manifest_version": 3,
  "name": "AlgoSync",
  "version": "1.0.0",
  "description": "Sync LeetCode, GFG, and HackerRank solutions to GitHub.",
  "permissions": [
    "identity",
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://*.geeksforgeeks.org/*",
    "https://*.hackerrank.com/*",
    "https://api.github.com/*",
    "https://github.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "assets/AlgoSync extension logo.png"
    }
  },
  "externally_connectable": {
    "matches": [
      "https://algosync-a537d.web.app/*",
      "https://algosync-a537d.firebaseapp.com/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/*",
        "https://*.geeksforgeeks.org/*",
        "https://*.hackerrank.com/*"
      ],
      "js": ["scripts/content-script.js"],
      "css": ["assets/badge.css"]
    }
  ],
  "icons": {
    "128": "assets/AlgoSync extension logo.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}